# ── Julia: cobertura e alocação ─────────────────────────────
*.jl.cov
*.jl.*.cov
*.jl.mem

# ── Julia: dependências e build ──────────────────────────────
deps/deps.jl
deps/build.log
deps/downloads/
deps/usr/
deps/src/

# ── Julia: documentação gerada ──────────────────────────────
docs/build/
docs/site/

# ── Julia: Manifest (lock file) ─────────────────────────────
# Ignorado para bibliotecas; commitar para aplicações reprodutíveis.
# Este projeto ignora para flexibilidade entre versões Julia.
Manifest*.toml

# ── Julia: preferências locais ──────────────────────────────
LocalPreferences.toml
JuliaLocalPreferences.toml

# ── Dados de simulação gerados ──────────────────────────────
# Saídas de scripts (plots, CSVs, HDF5) — potencialmente grandes
julia/data/output/
*.h5
*.hdf5

# Manter a estrutura de pastas sem commitar os arquivos
!julia/data/output/.gitkeep
!julia/data/input/.gitkeep

# ── Dados de entrada volumosos ──────────────────────────────
# Kernels SPICE NASA (binários, centenas de MB)
julia/data/spice/
*.bsp
*.tls
*.tf
*.tpc
*.bpc

# Arquivos TLE em massa (atualizar frequentemente, não versionar)
julia/data/input/*.tle
julia/data/input/*.txt

# ── Docker ──────────────────────────────────────────────────
# Volumes nomeados são gerenciados pelo Docker, não pelo Git
.docker/

# ── Claude Code ─────────────────────────────────────────────
# Contexto do projeto — mantido local, não publicar no GitHub
claude/

# Configuração local e cache de sessão (credenciais, histórico)
.claude/settings.local.json

# ── Relatórios de mudanças ───────────────────────────────────
# Gerados a cada commit, mantidos apenas localmente
.reports/

# ── Variáveis de ambiente / segredos ────────────────────────
.env
.env.*
!.env.example

# ── Sistema operacional ─────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*~
.fuse_hidden*
.Trash-*

# ── Editores ────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.vim/

# ── Pluto.jl ────────────────────────────────────────────────
# Cache interno de notebooks (regenerado automaticamente)
.julia/pluto_notebooks/
